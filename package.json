{
  "name": "algosprint",
  "private": true,
  "scripts": {
    "dev": "concurrently --names \"HUB,LLD,SD,MT\" --prefix-colors \"cyan,magenta,yellow,green\" \"npm run dev --prefix DSARevision\" \"npm run dev --prefix LLDDesign\" \"npm run dev --prefix SystemDesign\" \"npm run dev --prefix MultithreadingConcurrency\"",
    "dev:hub": "npm run dev --prefix DSARevision",
    "dev:lld": "npm run dev --prefix LLDDesign",
    "dev:sd":  "npm run dev --prefix SystemDesign",
    "dev:mt":  "npm run dev --prefix MultithreadingConcurrency",
    "build:lld": "npm run build --prefix LLDDesign",
    "build:hub": "npm run build --prefix DSARevision",
    "build:sd":  "npm run build --prefix SystemDesign",
    "build:mt":  "npm run build --prefix MultithreadingConcurrency"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
